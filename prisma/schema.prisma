generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MERCHANT
  COURIER
}

enum CourierStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BusinessStatus {
  PENDING
  ACTIVE
  BLOCKED
}

enum DeliveryStatus {
  AVAILABLE
  ACCEPTED
  PICKED_UP
  COMPLETED
  CANCELED
  ISSUE
}

enum CanceledBy {
  COURIER
  MERCHANT
  ADMIN
  SYSTEM
}

enum BillingCycleType {
  MONTHLY_FIXED // Dia 1 de cada ms
  FROM_SUBSCRIPTION_DATE // Aniversrio da adeso (padro)
}

enum PerDeliveryFeeType {
  FIXED // Valor fixo por entrega (ex: R$ 2,00)
  PERCENTAGE // % sobre o valor da entrega (ex: 5%)
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  OVERDUE // Fatura vencida  admin ainda no bloqueou
  SUSPENDED // Bloqueado manualmente pelo admin
  CANCELED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED // Isento/perdoado pelo admin
}

model User {
  id   String @id @default(uuid())
  name String
  role Role   @default(COURIER)

  phoneE164 String  @unique @map("phone_e164")
  email     String? @unique
  passwordHash String? @map("password_hash")

  isActive Boolean @default(true) @map("is_active")
  isRoot   Boolean @default(false) @map("is_root") // [NEW]

  // Courier Specific Fields
  cpf          String?       @unique
  cnh          String?       @unique
  vehiclePlate String?       @map("vehicle_plate")
  status       CourierStatus @default(PENDING) // Approval status

  cityId String? @map("city_id")
  city   City?   @relation("CourierCity", fields: [cityId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // relations
  otpTokens         OtpToken[]
  businesses        Business[]         @relation("BusinessOwner")
  pushSubscriptions PushSubscription[]

  // Delivery relations
  merchantDeliveries         Delivery[] @relation("MerchantDeliveries")
  courierDeliveries          Delivery[] @relation("CourierDeliveries")
  preferredCourierDeliveries Delivery[] @relation("PreferredCourierDeliveries")

  // Rating relations
  reviewsGiven              Rating[]   @relation("ReviewsGiven")
  reviewsReceived           Rating[]   @relation("ReviewsReceived")

  @@index([role])     // [NEW]
  @@index([isActive]) // [NEW]
  @@index([createdAt]) // [NEW]
  @@map("users")
}

model OtpToken {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  attempts   Int       @default(0)

  sentTo    String  @map("sent_to") // +55...
  requestIp String? @map("request_ip")
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("otp_tokens")
}

model Category {
  id   String @id @default(uuid())
  name String
  slug String @unique

  businesses Business[]

  @@map("categories")
}

model City {
  id       String  @id @default(uuid())
  name     String
  state    String
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  neighborhoods Neighborhood[]
  businesses    Business[]
  zones         DeliveryZone[]
  couriers      User[]         @relation("CourierCity")

  @@unique([name, state])
  @@map("cities")
}

model Business {
  id          String  @id @default(uuid())
  ownerId     String  @map("owner_id")
  categoryId  String  @map("category_id")
  name        String
  slug        String  @unique
  description String?
  phone       String?
  address     String?

  cityId String @map("city_id")
  city   City   @relation(fields: [cityId], references: [id])

  neighborhoodId String?       @map("neighborhood_id")
  neighborhood   Neighborhood? @relation(fields: [neighborhoodId], references: [id])

  defaultDeliveryPrice Decimal?       @map("default_delivery_price") @db.Decimal(10, 2)
  status               BusinessStatus @default(PENDING)
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  owner    User     @relation("BusinessOwner", fields: [ownerId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  deliveries Delivery[]

  // Billing relations
  subscription Subscription?
  invoices     Invoice[]

  @@index([ownerId])
  @@index([categoryId])
  @@index([cityId])
  @@index([neighborhoodId])
  @@map("businesses")
}

model Delivery {
  id String @id @default(uuid())

  businessId String   @map("business_id")
  business   Business @relation(fields: [businessId], references: [id])

  merchantId String @map("merchant_id")
  merchant   User   @relation("MerchantDeliveries", fields: [merchantId], references: [id])

  courierId String? @map("courier_id")
  courier   User?   @relation("CourierDeliveries", fields: [courierId], references: [id])

  preferredCourierId String?   @map("preferred_courier_id")
  preferredCourier   User?     @relation("PreferredCourierDeliveries", fields: [preferredCourierId], references: [id])
  preferredUntil     DateTime? @map("preferred_until")

  status DeliveryStatus @default(AVAILABLE)

  pickupAddress  String @map("pickup_address")
  dropoffAddress String @map("dropoff_address")

  destNeighborhoodId String?       @map("dest_neighborhood_id")
  destNeighborhood   Neighborhood? @relation(fields: [destNeighborhoodId], references: [id])

  price Decimal @db.Decimal(10, 2)
  notes String?

  acceptedAt   DateTime?   @map("accepted_at")
  pickedUpAt   DateTime?   @map("picked_up_at")
  completedAt  DateTime?   @map("completed_at")
  canceledAt   DateTime?   @map("canceled_at")
  canceledBy   CanceledBy? @map("canceled_by")
  cancelReason String?     @map("cancel_reason")

  expiresAt DateTime? @map("expires_at") // Deadline for AVAILABLE
  acceptBy  DateTime? @map("accept_by") // Deadline for PICKUP after ACCEPTED

  // [NEW] Issue reporting
  issueAt     DateTime? @map("issue_at")
  issueReason String?   @map("issue_reason")

  // [NEW] Track couriers who rejected or canceled the delivery
  rejectedBy  String[] @default([])

  // Rating relations
  ratings     Rating[]

  // Billing relations
  invoiceDeliveries InvoiceDelivery[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([merchantId]) // [NEW]
  @@index([courierId]) // [NEW]
  @@index([businessId]) // [NEW]
  @@index([createdAt])
  @@map("deliveries")
}

model DeliveryZone {
  id          String  @id @default(uuid())
  name        String
  description String?

  cityId String @map("city_id")
  city   City   @relation(fields: [cityId], references: [id])

  neighborhoods Neighborhood[]
  originRules   ZonePriceRule[] @relation("OriginZone")
  destRules     ZonePriceRule[] @relation("DestZone")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cityId])
  @@map("delivery_zones")
}

model Neighborhood {
  id             String       @id @default(uuid())
  name           String
  cityId         String       @map("city_id")
  city           City         @relation(fields: [cityId], references: [id])
  deliveryZoneId String       @map("delivery_zone_id")
  deliveryZone   DeliveryZone @relation(fields: [deliveryZoneId], references: [id])

  businesses Business[]
  deliveries Delivery[] // Deliveries bound to this neighborhood as destination

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, cityId])
  @@map("neighborhoods")
}

model ZonePriceRule {
  id           String       @id @default(uuid())
  originZoneId String       @map("origin_zone_id")
  originZone   DeliveryZone @relation("OriginZone", fields: [originZoneId], references: [id])
  destZoneId   String       @map("dest_zone_id")
  destZone     DeliveryZone @relation("DestZone", fields: [destZoneId], references: [id])

  price    Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([originZoneId, destZoneId])
  @@map("zone_price_rules")
}

model SystemConfig {
  key   String @id
  value String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

enum ProviderStatus {
  ACTIVE
  DISABLED
  BLOCKED
}

model NotificationProvider {
  id           String         @id @default(uuid())
  name         String
  providerKey  String         @unique @map("provider_key")
  status       ProviderStatus @default(DISABLED)
  priority     Int            @default(0)
  maxRetries   Int            @default(3) @map("max_retries")
  retryDelayMs Int            @default(1000) @map("retry_delay_ms")
  timeoutMs    Int            @default(5000) @map("timeout_ms")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_providers")
}

model Rating {
  id          String   @id @default(uuid())
  deliveryId  String   @map("delivery_id")
  delivery    Delivery @relation(fields: [deliveryId], references: [id])
  
  reviewerId  String   @map("reviewer_id")
  reviewer    User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  
  reviewedId  String   @map("reviewed_id")
  reviewed    User     @relation("ReviewsReceived", fields: [reviewedId], references: [id])

  role        Role     // MERCHANT ou COURIER

  score       Int      // 1 a 5
  tags        String[] // ["rápido", "atrasado"]
  comment     String?

  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([deliveryId, reviewerId])
  @@index([reviewedId])
  @@index([deliveryId])
  @@map("ratings")
}

model Plan {
  id          String  @id @default(uuid())
  name        String
  description String?
  isActive    Boolean @default(true) @map("is_active")
  isPublic    Boolean @default(true) @map("is_public") // false = customizado por loja

  // Mensalidade
  monthlyFee    Decimal? @map("monthly_fee") @db.Decimal(10, 2)
  deliveryLimit Int?     @map("delivery_limit") // entregas inclusas; null = ilimitado

  // Taxa por entrega (excedente ou total se sem mensalidade)
  perDeliveryFee     Decimal?            @map("per_delivery_fee") @db.Decimal(10, 4)
  perDeliveryFeeType PerDeliveryFeeType? @map("per_delivery_fee_type")

  // Ciclo de faturamento
  billingCycleType BillingCycleType @default(FROM_SUBSCRIPTION_DATE) @map("billing_cycle_type")

  // Trial
  trialDays Int? @map("trial_days") // null = sem trial

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@index([isActive, isPublic])
  @@map("plans")
}

model Subscription {
  id         String   @id @default(uuid())
  businessId String   @unique @map("business_id") // 1 assinatura ativa por loja
  business   Business @relation(fields: [businessId], references: [id])

  planId String @map("plan_id")
  plan   Plan   @relation(fields: [planId], references: [id])

  status          SubscriptionStatus @default(TRIAL)
  startDate       DateTime           @map("start_date")
  trialEndsAt     DateTime?          @map("trial_ends_at")
  nextBillingDate DateTime?          @map("next_billing_date")

  canceledAt    DateTime? @map("canceled_at")
  cancelReason  String?   @map("cancel_reason")
  suspendedAt   DateTime? @map("suspended_at")
  suspendReason String?   @map("suspend_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoices Invoice[]

  @@index([status])
  @@index([nextBillingDate])
  @@map("subscriptions")
}

model Invoice {
  id             String       @id @default(uuid())
  subscriptionId String       @map("subscription_id")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  businessId String   @map("business_id")
  business   Business @relation(fields: [businessId], references: [id])

  referenceMonth String // "2026-05"
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  dueDate        DateTime @map("due_date")

  monthlyFeeAmount   Decimal @default(0) @map("monthly_fee_amount") @db.Decimal(10, 2)
  deliveryCount      Int     @default(0) @map("delivery_count")
  includedDeliveries Int     @default(0) @map("included_deliveries") // cobertos pela franquia
  excessDeliveries   Int     @default(0) @map("excess_deliveries")
  deliveryFeeAmount  Decimal @default(0) @map("delivery_fee_amount") @db.Decimal(10, 2)
  totalAmount        Decimal @map("total_amount") @db.Decimal(10, 2)

  status InvoiceStatus @default(PENDING)
  paidAt DateTime?     @map("paid_at")
  paidBy String?       @map("paid_by") // userId do admin
  notes  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deliveries InvoiceDelivery[]

  @@unique([subscriptionId, referenceMonth]) // idempotncia
  @@index([businessId, status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceDelivery {
  invoiceId String  @map("invoice_id")
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  deliveryId String   @map("delivery_id")
  delivery   Delivery @relation(fields: [deliveryId], references: [id])

  deliveryValue Decimal @map("delivery_value") @db.Decimal(10, 2) // price no momento
  feeAmount     Decimal @map("fee_amount") @db.Decimal(10, 2) // taxa cobrada
  isIncluded    Boolean @default(false) @map("is_included") // coberto pela franquia

  @@id([invoiceId, deliveryId])
  @@map("invoice_deliveries")
}

